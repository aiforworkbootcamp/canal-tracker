{
  "version": 2,
  "builds": [
    {
      "src": "api/key.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/key",
      "dest": "/api/key.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
